{
  "meta": {
    "version": "2.0",
    "product": "SENP Credit Underwriting BRE",
    "last_updated": "2025-01"
  },

  "modules": [
    "KYC", "Profiling", "Household", "Business",
    "Income", "Expense", "Liability", "Banking",
